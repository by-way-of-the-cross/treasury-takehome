# Vision model access goes through the Vercel AI Gateway.
#
# On Vercel: a deployed app authenticates automatically via its OIDC token —
# no key needed here. Just enable AI Gateway for the project.
#
# Local dev (or non-Vercel hosts): create an AI Gateway key in the Vercel
# dashboard (Vercel > AI Gateway > API Keys) and set it here.
AI_GATEWAY_API_KEY=your-key-here

# Optional override; any gateway model string from vercel.com/ai-gateway/models.
# Defaults to google/gemini-2.5-flash (fast, vision-capable).
# GATEWAY_MODEL=google/gemini-2.5-flash
