# Vision model: Google Gemini via the AI SDK.
#
# Get a free API key from Google AI Studio (no credit card):
#   https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# Optional override; any vision-capable Gemini model id.
# Defaults to gemini-2.5-flash (fast, vision-capable).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: hard daily cap on total model calls, a backstop against quota
# abuse while the prototype is public. Defaults to 500/day.
# MAX_REQUESTS_PER_DAY=500
